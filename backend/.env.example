# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
 
# ─── PostgreSQL via Prisma ────────────────────────────────
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/aidiatrack_db"
 
# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=paste_your_generated_secret_here
JWT_EXPIRES_IN=7d
 
# ─── AI Microservice ───────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ─── Keep-Alive Ping Targets ───────────────────
KEEP_ALIVE_BACKEND_URL=https://aidiatrack-backend.onrender.com/ping
KEEP_ALIVE_AI_URL=https://aidiatrack-ai.onrender.com/health
 
# ─── Firebase Cloud Messaging ─────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

EMAIL_USER=
EMAIL_PASS=
 
# ─── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,exp://192.168.x.x:19000